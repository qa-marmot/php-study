---
---
<header class="fixed top-0 left-0 right-0 z-50 bg-indigo-700 text-white shadow-md">
  <div class="max-w-screen-xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight hover:text-indigo-200 transition-colors">
      <span class="text-2xl">🐘</span>
      <span>PHP8初級試験対策</span>
    </a>
    <nav class="flex items-center gap-4 text-sm">
      <a href="/" class="hover:text-indigo-200 transition-colors">トップ</a>
      <a href="/quiz/" class="hover:text-indigo-200 transition-colors">まとめ練習</a>
      <a
        href="https://www.php.net/manual/ja/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-indigo-200 transition-colors hidden sm:inline"
      >
        公式マニュアル ↗
      </a>

      <!-- 未ログイン時（初期非表示 → JS で表示切り替え） -->
      <a
        id="login-btn"
        href="/api/auth/login"
        class="hidden items-center gap-1.5 bg-white text-indigo-700 font-semibold text-xs px-3 py-1.5 rounded-lg hover:bg-indigo-50 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        GitHubでログイン
      </a>

      <!-- ログイン済み -->
      <div id="user-menu" class="hidden items-center gap-3">
        <a href="/history" class="text-indigo-200 hover:text-white transition-colors text-xs">履歴</a>
        <img id="user-avatar" src="" alt="" class="w-7 h-7 rounded-full border-2 border-indigo-400" />
        <span id="user-name" class="text-sm font-medium max-w-[80px] truncate hidden sm:inline"></span>
        <form method="POST" action="/api/auth/logout" class="m-0">
          <button type="submit" class="text-xs text-indigo-300 hover:text-white transition-colors">
            ログアウト
          </button>
        </form>
      </div>
    </nav>
  </div>
</header>

<script>
  type AuthUser = { sub: string; login: string; name: string; avatar: string };

  async function updateAuthUI(): Promise<void> {
    const loginBtn = document.getElementById('login-btn');
    const userMenu = document.getElementById('user-menu');
    const avatar = document.getElementById('user-avatar') as HTMLImageElement | null;
    const userName = document.getElementById('user-name');

    try {
      const res = await fetch('/api/auth/me');
      const user: AuthUser | null = await res.json();

      if (user) {
        loginBtn?.classList.add('hidden');
        userMenu?.classList.replace('hidden', 'flex');
        if (avatar) { avatar.src = user.avatar; avatar.alt = user.name; }
        if (userName) userName.textContent = user.name;
      } else {
        loginBtn?.classList.replace('hidden', 'flex');
        userMenu?.classList.add('hidden');
      }
    } catch {
      loginBtn?.classList.replace('hidden', 'flex');
    }
  }

  updateAuthUI();
</script>
