---
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { curriculum } from '../../../data/curriculum';
import { questions } from '../../../data/questions';

export function getStaticPaths() {
  return curriculum.map((chapter) => ({
    params: { slug: chapter.slug },
    props: { chapter },
  }));
}

const { chapter } = Astro.props;
const quizCount = questions.filter((q) => q.chapterSlug === chapter.slug).length;
const currentIndex = curriculum.findIndex((c) => c.slug === chapter.slug);
const prevChapter = currentIndex > 0 ? curriculum[currentIndex - 1] : null;
const nextChapter = currentIndex < curriculum.length - 1 ? curriculum[currentIndex + 1] : null;
---

<BaseLayout title={`第${chapter.chapter}章 ${chapter.title}`}>
  <div class="max-w-screen-lg mx-auto px-4 py-10">

    <!-- パンくず -->
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/" class="hover:text-indigo-600 transition-colors">トップ</a>
      <span>/</span>
      <span class="text-gray-600">{chapter.phase}</span>
      <span>/</span>
      <span class="text-gray-800 font-medium">第{chapter.chapter}章</span>
    </nav>

    <!-- ヘッダー -->
    <div class="mb-8">
      <p class="text-indigo-600 font-medium text-sm mb-1">{chapter.phase}</p>
      <h1 class="text-2xl font-bold text-gray-800">
        第{chapter.chapter}章　{chapter.title}
      </h1>
    </div>

    <!-- クイズバナー -->
    {quizCount > 0 && (
      <div class="mb-8 flex items-center justify-between bg-indigo-50 border border-indigo-200 rounded-xl px-5 py-4">
        <div>
          <p class="font-semibold text-indigo-800">練習問題</p>
          <p class="text-sm text-indigo-600">{quizCount}問の確認テストで理解度をチェック</p>
        </div>
        <a
          href={`/chapters/${chapter.slug}/quiz/`}
          class="bg-indigo-600 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-indigo-700 transition-colors"
        >
          テストを始める →
        </a>
      </div>
    )}

    <!-- セクション一覧 -->
    <div class="space-y-4">
      {chapter.sections.map((section) => (
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
          <div class="flex items-center gap-3 px-5 py-4 bg-gray-50 border-b border-gray-200">
            <span class="text-xs font-bold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded">
              {section.id}
            </span>
            <h2 class="font-semibold text-gray-800">{section.title}</h2>
          </div>
          {section.subsections && section.subsections.length > 0 && (
            <ul class="divide-y divide-gray-100">
              {section.subsections.map((sub) => (
                <li class="flex items-center gap-3 px-5 py-3 hover:bg-indigo-50 transition-colors">
                  <span class="text-xs text-gray-400 w-14 flex-shrink-0">{sub.id}</span>
                  <span class="text-gray-700 text-sm">{sub.title}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>

    <!-- 前後ナビ -->
    <div class="mt-10 flex justify-between gap-4">
      {prevChapter ? (
        <a
          href={`/chapters/${prevChapter.slug}/`}
          class="flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 transition-colors"
        >
          <span>←</span>
          <span>第{prevChapter.chapter}章　{prevChapter.title}</span>
        </a>
      ) : (
        <span />
      )}
      {nextChapter && (
        <a
          href={`/chapters/${nextChapter.slug}/`}
          class="flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 transition-colors"
        >
          <span>第{nextChapter.chapter}章　{nextChapter.title}</span>
          <span>→</span>
        </a>
      )}
    </div>

  </div>
</BaseLayout>
