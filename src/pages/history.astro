---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="学習履歴">
  <div class="max-w-screen-md mx-auto px-4 py-10">

    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/" class="hover:text-indigo-600 transition-colors">トップ</a>
      <span>/</span>
      <span class="text-gray-800 font-medium">学習履歴</span>
    </nav>

    <!-- ローディング -->
    <div id="loading" class="text-center py-16 text-gray-400">
      <p class="text-sm">読み込み中…</p>
    </div>

    <!-- 未ログイン -->
    <div id="unauthenticated" class="hidden text-center py-16">
      <p class="text-4xl mb-3">🔒</p>
      <p class="text-gray-600 mb-4">履歴を見るにはログインが必要です</p>
      <a href="/api/auth/login?redirect=/history" class="inline-flex items-center gap-2 bg-indigo-600 text-white font-medium px-5 py-2.5 rounded-lg hover:bg-indigo-700 transition-colors text-sm">
        GitHubでログイン
      </a>
    </div>

    <!-- ログイン済み -->
    <div id="authenticated" class="hidden">
      <div id="user-header" class="flex items-center gap-3 mb-8"></div>
      <div id="history-list"></div>
    </div>

  </div>
</BaseLayout>

<script>
  type AuthUser = { sub: string; login: string; name: string; avatar: string };
  type HistoryRow = { id: number; chapter_slug: string; score: number; total: number; answered_at: number };

  const chapterTitleMap: Record<string, string> = {
    'chapter-01': '第1章 イントロダクション',
    'chapter-02': '第2章 PHPの基本',
    'chapter-03': '第3章 演算子',
    'chapter-04': '第4章 制御構文',
    'chapter-05': '第5章 組み込み関数',
    'chapter-06': '第6章 ユーザー定義関数',
    'chapter-07': '第7章 標準クラスライブラリ',
    'chapter-08': '第8章 リクエスト情報',
    'chapter-09': '第9章 データベース連携',
    'chapter-10': '第10章 オブジェクト指向構文',
    'chapter-11': '第11章 高度なプログラミング',
    'all': '全章まとめ練習',
  };

  function formatDate(unixSec: number): string {
    return new Date(unixSec * 1000).toLocaleString('ja-JP', {
      year: 'numeric', month: '2-digit', day: '2-digit',
      hour: '2-digit', minute: '2-digit',
    });
  }

  async function init(): Promise<void> {
    const loading = document.getElementById('loading')!;
    const unauthenticated = document.getElementById('unauthenticated')!;
    const authenticated = document.getElementById('authenticated')!;

    try {
      const meRes = await fetch('/api/auth/me');
      const user: AuthUser | null = await meRes.json();

      if (!user) {
        loading.classList.add('hidden');
        unauthenticated.classList.remove('hidden');
        return;
      }

      // ユーザーヘッダー
      const userHeader = document.getElementById('user-header')!;
      userHeader.innerHTML = `
        <img src="${user.avatar}" alt="${user.name}" class="w-10 h-10 rounded-full border border-gray-200" />
        <div>
          <h1 class="text-2xl font-bold text-gray-800">学習履歴</h1>
          <p class="text-sm text-gray-400">${user.name}（@${user.login}）</p>
        </div>
      `;

      // 履歴取得
      const historyRes = await fetch('/api/quiz/history');
      const rows: HistoryRow[] = await historyRes.json();

      const historyList = document.getElementById('history-list')!;
      if (rows.length === 0) {
        historyList.innerHTML = `
          <div class="text-center py-16 text-gray-400">
            <p class="text-4xl mb-3">📋</p>
            <p class="text-sm">まだ記録がありません。練習問題を解いてみましょう！</p>
            <a href="/" class="mt-4 inline-block text-indigo-600 hover:underline text-sm">トップへ</a>
          </div>
        `;
      } else {
        historyList.innerHTML = '<div class="space-y-3">' + rows.map((row) => {
          const pct = Math.round((row.score / row.total) * 100);
          const color = pct >= 80
            ? 'text-green-700 bg-green-50 border-green-200'
            : pct >= 60
            ? 'text-yellow-700 bg-yellow-50 border-yellow-200'
            : 'text-red-700 bg-red-50 border-red-200';
          const barColor = pct >= 80 ? 'bg-green-500' : pct >= 60 ? 'bg-yellow-400' : 'bg-red-400';
          const title = chapterTitleMap[row.chapter_slug] ?? row.chapter_slug;
          return `
            <div class="flex items-center gap-4 rounded-xl border p-4 ${color}">
              <div class="flex-1 min-w-0">
                <p class="font-medium text-sm truncate">${title}</p>
                <p class="text-xs opacity-60 mt-0.5">${formatDate(row.answered_at)}</p>
              </div>
              <div class="text-right flex-shrink-0">
                <p class="text-lg font-bold">${row.score}<span class="text-xs font-normal opacity-60"> / ${row.total}</span></p>
                <div class="w-20 bg-white/60 rounded-full h-1.5 mt-1">
                  <div class="${barColor} h-1.5 rounded-full" style="width:${pct}%"></div>
                </div>
              </div>
            </div>
          `;
        }).join('') + '</div>';
      }

      loading.classList.add('hidden');
      authenticated.classList.remove('hidden');
    } catch {
      loading.innerHTML = '<p class="text-sm text-red-500">読み込みに失敗しました</p>';
    }
  }

  init();
</script>
